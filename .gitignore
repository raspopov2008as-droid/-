def calculator():
    """Простой калькулятор, выполняющий базовые арифметические операции."""

    num1 = float(input("Введите первое число: "))
    operator = input("Введите оператор (+, -, *, /): ")
    num2 = float(input("Введите второе число: "))

    if operator == '+':
        result = num1 + num2
        print(f"Результат: {num1} + {num2} = {result}")
    elif operator == '-':
        result = num1 - num2
        print(f"Результат: {num1} - {num2} = {result}")
    elif operator == '*':
        result = num1 * num2
        print(f"Результат: {num1} * {num2} = {result}")
    elif operator == '/':
        if num2 != 0:  # Проверка деления на ноль
            result = num1 / num2
            print(f"Результат: {num1} / {num2} = {result}")
        else:
            print("Ошибка: Деление на ноль недопустимо.")
    else:
        print("Ошибка: Неверный оператор. Используйте +, -, *, /.")

# Вызываем функцию калькулятора
calculator()
